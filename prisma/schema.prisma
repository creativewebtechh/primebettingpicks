generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model advertisement {
  id        String    @id @default(cuid())
  name      String
  position  String
  code      String
  active    Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model analyticsevent {
  id        String   @id @default(cuid())
  event     String
  page      String
  metadata  String?
  ip        String?
  createdAt DateTime @default(now())
}

model bookmaker {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique(map: "Bookmaker_slug_key")
  logo      String?
  website   String?
  rating    Float    @default(0)
  bonus     String?
  features String?
  active    Boolean  @default(true)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model contactmessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model expert {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique(map: "Expert_slug_key")
  avatar           String?
  bio              String?
  specialties      String?
  winRate          Float        @default(0)
  totalPredictions Int          @default(0)
  verified         Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  prediction       prediction[]
}

model league {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique(map: "League_slug_key")
  logo        String?
  country     String
  tier        Int           @default(0)
  sport       String        @default("football")
  season      String
  featured    Boolean       @default(false)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  match       match[]
  newsarticle newsarticle[]
  team        team[]
  fixture     fixture[]
  topscorer   topscorer[]
  standing     standing[]
}

model match {
  id                          String      @id @default(cuid())
  externalId                  String?
  leagueId                    String
  homeTeamId                  String
  awayTeamId                  String
  status                      String      @default("upcoming")
  date                        DateTime
  venue                       String?
  round                       String?
  homeScore                   Int?
  awayScore                   Int?
  homeHalfScore               Int?
  awayHalfScore               Int?
  homeRedCards                Int?
  awayRedCards                Int?
  homeYellowCards             Int?
  awayYellowCards             Int?
  possessionHome              Int?
  possessionAway              Int?
  shotsHome                   Int?
  shotsAway                   Int?
  shotsOnTargetHome           Int?
  shotsOnTargetAway           Int?
  cornersHome                 Int?
  cornersAway                 Int?
  foulsHome                   Int?
  foulsAway                   Int?
  injuries                    String?
  liveMinute                  Int?
  homeForm                    String?
  awayForm                    String?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
  team_match_awayTeamIdToteam team        @relation("match_awayTeamIdToteam", fields: [awayTeamId], references: [id], map: "Match_awayTeamId_fkey")
  team_match_homeTeamIdToteam team        @relation("match_homeTeamIdToteam", fields: [homeTeamId], references: [id], map: "Match_homeTeamId_fkey")
  league                      league      @relation(fields: [leagueId], references: [id], map: "Match_leagueId_fkey")
  prediction                  prediction?
  livescore                   livescore?

  @@index([awayTeamId], map: "Match_awayTeamId_fkey")
  @@index([homeTeamId], map: "Match_homeTeamId_fkey")
  @@index([leagueId], map: "Match_leagueId_fkey")
}

model newsarticle {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique(map: "NewsArticle_slug_key")
  excerpt         String
  content         String
  author          String
  image           String?
  category        String
  tags            String?
  published       Boolean  @default(false)
  featured        Boolean  @default(false)
  leagueId        String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  league          league?  @relation(fields: [leagueId], references: [id], map: "NewsArticle_leagueId_fkey")

  @@index([leagueId], map: "NewsArticle_leagueId_fkey")
}

model prediction {
  id                 String    @id @default(cuid())
  matchId            String    @unique(map: "Prediction_matchId_key")
  expertId           String?
  predictedHomeScore Int
  predictedAwayScore Int
  homeWinProbability Float
  awayWinProbability Float
  drawProbability    Float
  tip                String
  analysis           String?
  bettingTips        String?
  result             String    @default("pending")
  published          Boolean   @default(false)
  featured           Boolean   @default(false)
  price              Int?
  premium            Boolean   @default(false)
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  expert             expert?   @relation(fields: [expertId], references: [id], map: "Prediction_expertId_fkey")
  match              match     @relation(fields: [matchId], references: [id], map: "Prediction_matchId_fkey")
  payment            payment[]

  @@index([expertId], map: "Prediction_expertId_fkey")
}

model payment {
  id           String       @id @default(cuid())
  userId       String
  predictionId String
  amount       Int
  currency     String       @default("NGN")
  reference    String       @unique(map: "Payment_reference_key")
  paystackRef  String?
  status       String       @default("pending")
  metadata     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         user         @relation(fields: [userId], references: [id], map: "Payment_userId_fkey")
  prediction   prediction   @relation(fields: [predictionId], references: [id], map: "Payment_predictionId_fkey")

  @@index([userId], map: "Payment_userId_fkey")
  @@index([predictionId], map: "Payment_predictionId_fkey")
}

model subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique(map: "Subscription_userId_key")
  plan               String    @default("free")
  paystackCode       String?
  status             String    @default("active")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               user      @relation(fields: [userId], references: [id], map: "Subscription_userId_fkey")

  @@index([userId], map: "Subscription_userId_fkey")
}

model seodata {
  id          String   @id @default(cuid())
  page        String   @unique(map: "SEOData_page_key")
  title       String
  description String
  keywords    String?
  ogImage     String?
  canonical   String?
  schema      String?
  updatedAt   DateTime @updatedAt
}

model team {
  id                           String   @id @default(cuid())
  name                         String
  slug                         String   @unique(map: "Team_slug_key")
  shortName                    String
  logo                         String?
  country                      String?
  stadium                      String?
  foundedYear                  Int?
  leagueId                     String
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  match_match_awayTeamIdToteam match[]  @relation("match_awayTeamIdToteam")
  match_match_homeTeamIdToteam match[]  @relation("match_homeTeamIdToteam")
  fixture_awayTeamIdToteam     fixture[] @relation("fixture_awayTeamIdToteam")
  fixture_homeTeamIdToteam     fixture[] @relation("fixture_homeTeamIdToteam")
  league                       league   @relation(fields: [leagueId], references: [id], map: "Team_leagueId_fkey")
  standing                     standing[]
  topscorer                    topscorer[]

  @@index([leagueId], map: "Team_leagueId_fkey")
}

model user {
  id                 String          @id @default(cuid())
  name               String?
  email              String          @unique(map: "User_email_key")
  password           String
  role               String          @default("user") // user | editor | moderator | admin | superadmin
  avatar             String?
  emailVerified      Boolean         @default(false)
  favorites          String?
  stripeCustomerId   String?
  paystackCustomerId String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  payment            payment[]
  subscription       subscription?
  notification       notification[]
  auditlog           auditlog[]
  fixture            fixture[]
}

model notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], map: "Notification_userId_fkey")

  @@index([userId], map: "Notification_userId_fkey")
}

model auditlog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  oldData   String?
  newData   String?
  ip        String?
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], map: "AuditLog_userId_fkey")

  @@index([userId], map: "AuditLog_userId_fkey")
  @@index([entity, entityId], map: "AuditLog_entity_entityId_idx")
}

model fixture {
  id             String   @id @default(cuid())
  externalId     String
  leagueId       String
  homeTeamId     String
  awayTeamId     String
  date           DateTime
  status         String   @default("scheduled")
  venue          String?
  referee        String?
  round          String?
  season         String?
  homeScore      Int?
  awayScore      Int?
  homeHalfScore  Int?
  awayHalfScore  Int?
  odds           String?
  syncedByUserId String?
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  league         league   @relation(fields: [leagueId], references: [id], map: "Fixture_leagueId_fkey")
  homeTeam       team     @relation("fixture_homeTeamIdToteam", fields: [homeTeamId], references: [id], map: "Fixture_homeTeamId_fkey")
  awayTeam       team     @relation("fixture_awayTeamIdToteam", fields: [awayTeamId], references: [id], map: "Fixture_awayTeamId_fkey")
  syncedBy       user?    @relation(fields: [syncedByUserId], references: [id], map: "Fixture_syncedByUserId_fkey")

  @@index([externalId], map: "Fixture_externalId_key")
  @@index([leagueId], map: "Fixture_leagueId_fkey")
  @@index([homeTeamId], map: "Fixture_homeTeamId_fkey")
  @@index([awayTeamId], map: "Fixture_awayTeamId_fkey")
  @@index([syncedByUserId], map: "Fixture_syncedByUserId_fkey")
  @@index([date], map: "Fixture_date_idx")
}

model livescore {
  id          String   @id @default(cuid())
  matchId     String   @unique(map: "LiveScore_matchId_key")
  minute      Int?
  status      String   @default("not_started")
  homeScore   Int?
  awayScore   Int?
  events      String?
  stats       String?
  lastUpdated DateTime @default(now())
  match       match    @relation(fields: [matchId], references: [id], map: "LiveScore_matchId_fkey")
}

model topscorer {
  id         String   @id @default(cuid())
  leagueId   String
  teamId     String
  playerName String
  goals      Int      @default(0)
  assists    Int      @default(0)
  season     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  league     league   @relation(fields: [leagueId], references: [id], map: "TopScorer_leagueId_fkey")
  team       team     @relation(fields: [teamId], references: [id], map: "TopScorer_teamId_fkey")

  @@index([leagueId], map: "TopScorer_leagueId_fkey")
  @@index([teamId], map: "TopScorer_teamId_fkey")
}

model standing {
  id            String   @id @default(cuid())
  leagueId      String
  teamId        String
  position      Int
  played        Int      @default(0)
  won           Int      @default(0)
  drawn         Int      @default(0)
  lost          Int      @default(0)
  goalsFor      Int      @default(0)
  goalsAgainst  Int      @default(0)
  goalDifference Int     @default(0)
  points        Int      @default(0)
  form          String?
  season        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  league        league   @relation(fields: [leagueId], references: [id], map: "Standing_leagueId_fkey")
  team          team     @relation(fields: [teamId], references: [id], map: "Standing_teamId_fkey")

  @@index([leagueId], map: "Standing_leagueId_fkey")
  @@index([teamId], map: "Standing_teamId_fkey")
  @@index([leagueId, season, position], map: "Standing_leagueId_season_position_idx")
}

model scheduledpublish {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  publishAt  DateTime
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId], map: "ScheduledPublish_entityType_entityId_idx")
  @@index([publishAt, status], map: "ScheduledPublish_publishAt_status_idx")
}
